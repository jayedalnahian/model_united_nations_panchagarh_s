model GalleryItem {
  id        String      @id @default(cuid())
  mediaUrl  String
  caption   String?
  type      GalleryType @default(IMAGE)
  order     Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum GalleryType {
  IMAGE
  VIDEO
}