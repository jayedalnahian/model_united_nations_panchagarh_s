<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Verification Code</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f8fafc; color: #1e293b;">
    <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);">
        <!-- Header / Brand -->
        <tr>
            <td align="center" style="padding: 40px 40px 20px;">
                <div style="font-size: 24px; font-weight: 800; color: #6366f1; letter-spacing: -0.5px;">
                    SkillBridge<span style="color: #1e293b;">Secure</span>
                </div>
            </td>
        </tr>

        <!-- Content Area -->
        <tr>
            <td style="padding: 20px 40px 40px;">
                <h1 style="margin: 0 0 16px; font-size: 24px; font-weight: 700; color: #0f172a; text-align: center;">Verify your account</h1>
                <p style="margin: 0 0 24px; font-size: 16px; line-height: 1.6; color: #475569; text-align: center;">
                    Hello <strong><%= name %></strong>,<br>
                    To complete your registration at SkillBridge, please use the following one-time password (OTP):
                </p>

                <!-- OTP Display -->
                <div style="background-color: #f1f5f9; border-radius: 12px; padding: 24px; text-align: center; margin-bottom: 24px;">
                    <div style="font-family: 'JetBrains Mono', 'Roboto Mono', monospace; font-size: 42px; font-weight: 800; letter-spacing: 12px; color: #6366f1; margin: 0;">
                        <%= otp %>
                    </div>
                </div>

                <p style="margin: 0 0 32px; font-size: 14px; line-height: 1.6; color: #64748b; text-align: center;">
                    This code is valid for <strong>2 minutes</strong>.<br>
                    If you didn't request this code, you can safely ignore this email.
                </p>

                <div style="text-align: center;">
                    <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 32px 0;">
                    <p style="margin: 0; font-size: 12px; color: #94a3b8; line-height: 1.5;">
                        &copy; 2024 SkillBridge Tutoring Platform. All rights reserved.<br>
                        Helping you bridge the gap between learning and mastery.
                    </p>
                </div>
            </td>
        </tr>
    </table>
</body>
</html>